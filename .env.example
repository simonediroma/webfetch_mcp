# WEBFETCH_HEADERS — domain-scoped headers for outbound HTTP requests.
#
# Format: a JSON object where each key is either:
#   "*"          → headers applied to ALL requests (global/catch-all)
#   "domain.tld" → headers applied only when the request hostname ends with this value
#                  e.g. "example.com" matches "example.com" and "www.example.com"
#
# Headers are merged in this order (later wins on conflict):
#   global ("*")  →  domain-specific  →  per-call extra_headers from Claude
#
# Must be a single-line JSON string when set as an environment variable.
WEBFETCH_HEADERS={"*": {"User-Agent": "MyBot/1.0"}, "example.com": {"X-Akamai-Token": "token-for-example"}, "example2.com": {"X-Akamai-Token": "token-for-example2"}}
